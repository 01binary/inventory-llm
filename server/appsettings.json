{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppPaths": {
    "DatabasePath": "/data/inventory.db",
    "SqlScriptsPath": "db",
    "SystemPromptPath": "SYSTEM_PROMPT.md",
    "StartupPromptPath": "STARTUP_PROMPT.md",
    "FewShotPromptsPath": "FEW_SHOT_PROMPTS.json"
  },
  "ModelServices": {
    "LlmBaseUrl": "http://host.docker.internal:1234",
    "LlmModel": "auto",
    "McpServerUrl": "http://localhost:8080/mcp",
    "LlmCompletionPath": "/v1/chat/completions",
    "LlmHealthPath": "/v1/models"
  },
  "Speech": {
    "DefaultSttLanguage": "en-US",
    "DefaultTtsLanguage": "en-US",
    "PreferredTtsVoiceName": "Google US English"
  }
}
